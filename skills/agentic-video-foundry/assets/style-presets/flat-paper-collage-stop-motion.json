{
  "id": "flat-paper-collage-stop-motion",
  "version": 1,
  "renderer": "remotion",
  "canvas": {
    "background": "#F5EDD8",
    "safeArea": {
      "top": 120,
      "right": 150,
      "bottom": 300,
      "left": 72
    }
  },
  "palette": {
    "ink": "#25221F",
    "paper": "#F5EDD8",
    "clay": "#8B6340",
    "clayDark": "#6B4A2E",
    "grass": "#5C8A3A",
    "sky": "#7EC8E3",
    "accent": "#9B7EBD",
    "warmYellow": "#F0C75E",
    "line": "#3D2B1F",
    "edge": "#FAF6EC"
  },
  "typography": {
    "languagePriority": "zh-CN",
    "fontFamily": "PingFang SC, Noto Sans CJK SC, sans-serif",
    "maxHeadlineCjk": 12,
    "maxLabelCjk": 8,
    "maxLabelsPerFrame": 2
  },
  "paper": {
    "treatment": "illustrated-cutout",
    "textureOpacity": 0.16,
    "edge": {
      "kind": "torn-or-cut-white",
      "roughness": 0.36,
      "width": 8
    },
    "shadow": {
      "offsetX": 12,
      "offsetY": 14,
      "blur": 12,
      "opacity": 0.2
    }
  },
  "motion": {
    "holdPattern": [
      4,
      3,
      6,
      2,
      5,
      3
    ],
    "resultHoldFrames": [
      15,
      36
    ],
    "microSway": {
      "maxPixels": 6,
      "maxDegrees": 1,
      "asynchronous": true
    },
    "maxRotationDegrees": 3,
    "maxSettleOvershoots": 1,
    "seed": "agentic-video-foundry-paper-v1",
    "forbidden": [
      "continuous-floating",
      "shape-morphing",
      "unseeded-random-jitter",
      "simultaneous-everything"
    ]
  },
  "density": {
    "maxHeroes": 1,
    "maxSupporters": 2,
    "maxPaperGroups": 6,
    "subjectOccupancy": [
      0.35,
      0.6
    ],
    "decorationsAreStatic": true
  },
  "evidenceTreatment": "pasted-original-window",
  "transitions": {
    "allowed": [
      "paper-wipe",
      "hand-set-slide",
      "page-push",
      "tape-stick"
    ],
    "maxFamiliesPerVideo": 2
  }
}
